///|
fn concat_bytes(parts : Array[Bytes]) -> Bytes {
  if parts.is_empty() {
    b""
  } else {
    let mut total = 0
    for part in parts {
      total = total + part.length()
    }
    let out : Array[Byte] = Array::make(total, 0)
    let mut offset = 0
    for part in parts {
      for b in part {
        out[offset] = b
        offset = offset + 1
      }
    }
    Bytes::from_array(out)
  }
}

///|
fn merge_byte_maps(parts : Array[Map[String, Bytes]]) -> Map[String, Bytes] {
  let out : Map[String, Bytes] = {}
  for part in parts {
    for key, value in part {
      out[key] = value
    }
  }
  out
}

