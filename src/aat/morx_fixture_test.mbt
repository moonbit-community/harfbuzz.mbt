///|
struct ExpectedGlyph {
  name : String
  cluster : Int
  x_advance : Int
  x_offset : Int
  y_offset : Int
} derive(Eq, Show)

///|
fn bytes_to_ascii_string(bytes : Bytes) -> String {
  let sb = StringBuilder::new(size_hint=bytes.length())
  for b in bytes {
    sb.write_char(b.to_char())
  }
  sb.to_string()
}

///|
fn build_glyph_name_map(post : @sfnt.PostTable) -> Map[String, UInt] {
  let map : Map[String, UInt] = {}
  if post.version == 0x00010000 {
    for i in 0..<post_standard_names.length() {
      map[post_standard_names[i]] = i.reinterpret_as_uint()
    }
    return map
  }
  if post.version == 0x00020000 {
    let indices = match post.glyph_name_indices {
      None => return map
      Some(value) => value
    }
    let custom = match post.custom_names {
      None => []
      Some(value) => value
    }
    for i in 0..<indices.length() {
      let index = indices[i]
      if index < 0 {
        continue
      }
      if index < post_standard_names.length() {
        map[post_standard_names[index]] = i.reinterpret_as_uint()
      } else {
        let custom_index = index - post_standard_names.length()
        if custom_index >= 0 && custom_index < custom.length() {
          map[bytes_to_ascii_string(custom[custom_index])] = i.reinterpret_as_uint()
        }
      }
    }
  }
  map
}

///|
fn shape_with_aat(
  font : @font.Font,
  codepoints : Array[UInt],
) -> @buffer.Buffer raise {
  let buffer = @buffer.Buffer::new()
  for cp in codepoints {
    buffer.add_codepoint(cp)
  }
  match @shape.shape(font, buffer, shapers=["aat"]) {
    Err(err) => fail("shape failed: \{err}")
    Ok(_) => ()
  }
  buffer
}

///|
fn assert_shaped(
  buffer : @buffer.Buffer,
  name_map : Map[String, UInt],
  expected : Array[ExpectedGlyph],
) -> Unit raise {
  let infos = buffer.infos()
  let positions = buffer.positions()
  assert_eq(infos.length(), expected.length())
  assert_eq(positions.length(), expected.length())
  for i in 0..<expected.length() {
    let exp = expected[i]
    let gid = match name_map.get(exp.name) {
      None => fail("missing glyph name \{exp.name}")
      Some(value) => value
    }
    assert_eq(infos[i].codepoint, gid)
    assert_eq(infos[i].cluster, exp.cluster)
    assert_eq(positions[i].x_advance, exp.x_advance)
    assert_eq(positions[i].x_offset, exp.x_offset)
    assert_eq(positions[i].y_offset, exp.y_offset)
  }
}

