///|
fn find_syllables_use(
  categories : Array[UInt],
  is_mark : Array[Bool],
) -> Array[Int] {
  let len = categories.length()
  let syllables : Array[Int] = Array::make(len, 0)
  if len == 0 || is_mark.length() != len {
    return syllables
  }
  let filtered_indices : Array[Int] = []
  let filtered_categories : Array[UInt] = []
  for i in 0..<len {
    let category = categories[i]
    if category == use_syllable_machine_ex_CGJ {
      continue
    }
    if category == use_syllable_machine_ex_ZWNJ {
      let mut j = i + 1
      let mut keep = true
      while j < len {
        let next_category = categories[j]
        if next_category == use_syllable_machine_ex_CGJ {
          j = j + 1
          continue
        }
        keep = !is_mark[j]
        break
      }
      if !keep {
        continue
      }
    }
    filtered_indices.push(i)
    filtered_categories.push(category)
  }
  if filtered_indices.is_empty() {
    return syllables
  }
  let filtered_len = filtered_categories.length()
  let mut cs = use_machine_start
  let mut ts = 0
  let mut te = 0
  let mut act = 0
  let mut p = 0
  let pe = filtered_len
  let eof = filtered_len
  let mut syllable_serial = 1
  fn found_syllable(start : Int, end : Int, syllable_type : Int) -> Unit {
    if start < 0 || start >= filtered_indices.length() {
      return ()
    }
    let start_idx = filtered_indices[start]
    let end_idx = if end <= start {
      start_idx
    } else if end >= filtered_indices.length() {
      len
    } else {
      filtered_indices[end]
    }
    if start_idx < 0 || end_idx > len || start_idx >= end_idx {
      return ()
    }
    for i in start_idx..<end_idx {
      syllables[i] = (syllable_serial << 4) | syllable_type
    }
    syllable_serial = syllable_serial + 1
    if syllable_serial == 16 {
      syllable_serial = 1
    }
  }

  while true {
    if p == pe {
      break
    }
    if use_machine_from_state_actions[cs] == 3 {
      ts = p
    }
    let keys_index = cs << 1
    let slen = use_machine_key_spans[cs]
    let inds_index = use_machine_index_offsets[cs]
    let category = filtered_categories[p].reinterpret_as_int()
    let mut trans = 0
    if slen > 0 &&
      use_machine_trans_keys[keys_index] <= category &&
      category <= use_machine_trans_keys[keys_index + 1] {
      trans = use_machine_indicies[inds_index +
        (category - use_machine_trans_keys[keys_index])]
    } else {
      trans = use_machine_indicies[inds_index + slen]
    }
    cs = use_machine_trans_targs[trans]
    let action = use_machine_trans_actions[trans]
    if action != 0 {
      match action {
        7 => te = p + 1
        16 => {
          te = p + 1
          found_syllable(ts, te, use_syllable_type_virama_terminated_cluster)
        }
        14 => {
          te = p + 1
          found_syllable(ts, te, use_syllable_type_sakot_terminated_cluster)
        }
        12 => {
          te = p + 1
          found_syllable(ts, te, use_syllable_type_standard_cluster)
        }
        20 => {
          te = p + 1
          found_syllable(
            ts, te, use_syllable_type_number_joiner_terminated_cluster,
          )
        }
        18 => {
          te = p + 1
          found_syllable(ts, te, use_syllable_type_numeral_cluster)
        }
        10 => {
          te = p + 1
          found_syllable(ts, te, use_syllable_type_symbol_cluster)
        }
        25 => {
          te = p + 1
          found_syllable(ts, te, use_syllable_type_hieroglyph_cluster)
        }
        5 => {
          te = p + 1
          found_syllable(ts, te, use_syllable_type_broken_cluster)
        }
        4 => {
          te = p + 1
          found_syllable(ts, te, use_syllable_type_non_cluster)
        }
        15 => {
          te = p
          p = p - 1
          found_syllable(ts, te, use_syllable_type_virama_terminated_cluster)
        }
        13 => {
