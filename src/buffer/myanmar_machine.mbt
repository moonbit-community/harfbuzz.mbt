fn find_syllables_myanmar(categories : Array[UInt]) -> Array[Int] {
  let len = categories.length()
  let syllables : Array[Int] = Array::make(len, 0)
  let mut cs = myanmar_machine_start
  let mut ts = 0
  let mut te = 0
  let mut act = 0
  let mut p = 0
  let pe = len
  let eof = len
  let mut syllable_serial = 1
  fn found_syllable(start : Int, end : Int, syllable_type : Int) -> Unit {
    if start < 0 || end > len || start >= end {
      return ()
    }
    for i in start..<end {
      syllables[i] = (syllable_serial << 4) | syllable_type
    }
    syllable_serial = syllable_serial + 1
    if syllable_serial == 16 {
      syllable_serial = 1
    }
  }

  while true {
    if p == pe {
      break
    }
    if myanmar_machine_from_state_actions[cs] == 2 {
      ts = p
    }
    let keys_index = cs << 1
    let slen = myanmar_machine_key_spans[cs]
    let inds_index = myanmar_machine_index_offsets[cs]
    let category = categories[p].reinterpret_as_int()
    let mut trans = 0
    if slen > 0 && myanmar_machine_trans_keys[keys_index] <= category && category <= myanmar_machine_trans_keys[keys_index + 1] {
      trans = myanmar_machine_indicies[inds_index + (category - myanmar_machine_trans_keys[keys_index])]
    } else {
      trans = myanmar_machine_indicies[inds_index + slen]
    }
    cs = myanmar_machine_trans_targs[trans]
    let action = myanmar_machine_trans_actions[trans]
    if action != 0 {
      match action {
        8 => { te = p + 1; found_syllable(ts, te, myanmar_syllable_type_consonant) }
        4 => { te = p + 1; found_syllable(ts, te, myanmar_syllable_type_non_myanmar) }
        10 => { te = p + 1; found_syllable(ts, te, myanmar_syllable_type_broken) }
        3 => { te = p + 1; found_syllable(ts, te, myanmar_syllable_type_non_myanmar) }
        7 => { te = p; p = p - 1; found_syllable(ts, te, myanmar_syllable_type_consonant) }
        9 => { te = p; p = p - 1; found_syllable(ts, te, myanmar_syllable_type_broken) }
        12 => { te = p; p = p - 1; found_syllable(ts, te, myanmar_syllable_type_non_myanmar) }
        11 => {
          match act {
            2 => { p = te - 1; found_syllable(ts, te, myanmar_syllable_type_non_myanmar) }
            3 => { p = te - 1; found_syllable(ts, te, myanmar_syllable_type_broken) }
            _ => ()
          }
        }
        6 => { te = p + 1; act = 2 }
        5 => { te = p + 1; act = 3 }
        _ => ()
      }
    }
    if myanmar_machine_to_state_actions[cs] == 1 {
      ts = 0
    }
    p = p + 1
  }
  if p == eof {
    let eof_trans = myanmar_machine_eof_trans[cs]
    if eof_trans > 0 {
      let trans = eof_trans - 1
      cs = myanmar_machine_trans_targs[trans]
      let action = myanmar_machine_trans_actions[trans]
      if action != 0 {
        match action {
          8 => { te = p + 1; found_syllable(ts, te, myanmar_syllable_type_consonant) }
          4 => { te = p + 1; found_syllable(ts, te, myanmar_syllable_type_non_myanmar) }
          10 => { te = p + 1; found_syllable(ts, te, myanmar_syllable_type_broken) }
          3 => { te = p + 1; found_syllable(ts, te, myanmar_syllable_type_non_myanmar) }
          7 => { te = p; p = p - 1; found_syllable(ts, te, myanmar_syllable_type_consonant) }
          9 => { te = p; p = p - 1; found_syllable(ts, te, myanmar_syllable_type_broken) }
          12 => { te = p; p = p - 1; found_syllable(ts, te, myanmar_syllable_type_non_myanmar) }
          11 => {
            match act {
              2 => { p = te - 1; found_syllable(ts, te, myanmar_syllable_type_non_myanmar) }
              3 => { p = te - 1; found_syllable(ts, te, myanmar_syllable_type_broken) }
              _ => ()
            }
          }
          6 => { te = p + 1; act = 2 }
          5 => { te = p + 1; act = 3 }
          _ => ()
        }
      }
      if myanmar_machine_to_state_actions[cs] == 1 {
        ts = 0
      }
    }
  }
  syllables
}
