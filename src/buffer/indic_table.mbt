priv struct IndicRange {
  start : UInt
  end : UInt
  offset : Int
}

let indic_ranges : Array[IndicRange] = [
  IndicRange::{ start: 0x0028U, end: 0x003FU, offset: 0 },
  IndicRange::{ start: 0x00B0U, end: 0x00D7U, offset: 24 },
  IndicRange::{ start: 0x0900U, end: 0x0D7FU, offset: 64 },
  IndicRange::{ start: 0x1000U, end: 0x109FU, offset: 1216 },
  IndicRange::{ start: 0x1780U, end: 0x17EFU, offset: 1376 },
  IndicRange::{ start: 0x1CD0U, end: 0x1CFFU, offset: 1488 },
  IndicRange::{ start: 0x2008U, end: 0x2027U, offset: 1536 },
  IndicRange::{ start: 0x2070U, end: 0x2087U, offset: 1568 },
  IndicRange::{ start: 0x25F8U, end: 0x25FFU, offset: 1592 },
  IndicRange::{ start: 0xA8E0U, end: 0xA8FFU, offset: 1600 },
  IndicRange::{ start: 0xA9E0U, end: 0xA9FFU, offset: 1632 },
