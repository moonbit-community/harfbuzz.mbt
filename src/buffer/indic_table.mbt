]

let indic_special_00a0 : UInt = 1034U
let indic_special_25cc : UInt = 1035U

let indic_default : UInt = 3584U

fn indic_get_categories(u : UInt) -> UInt {
  if u == 0x00A0U {
    return indic_special_00a0
  }
  if u == 0x25CCU {
    return indic_special_25cc
  }
  for range in indic_ranges {
    if u >= range.start && u <= range.end {
      let index = (u - range.start).reinterpret_as_int() + range.offset
      return indic_table[index]
    }
  }
  indic_default
}

fn indic_category(value : UInt) -> UInt {
  value & 0xffU
}
