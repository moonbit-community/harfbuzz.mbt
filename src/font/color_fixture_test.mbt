///|
test "cpal v0 parse" {
  let font = Font::from_bytes(build_font_bytes_cpal_v0())
  let cpal = match font.cpal() {
    Err(err) => fail("cpal v0 parse failed: \{err}")
    Ok(None) => fail("cpal v0 table missing")
    Ok(Some(cpal)) => cpal
  }
  assert_eq(cpal.version, 0)
  assert_true(cpal.num_palettes > 0)
  assert_true(cpal.num_colors > 0)
  let colors = cpal.palette_colors(0)
  assert_eq(colors.length(), cpal.num_colors)
}

///|
test "cpal v1 parse" {
  let font = Font::from_bytes(build_font_bytes_cpal_v1())
  let cpal = match font.cpal() {
    Err(err) => fail("cpal v1 parse failed: \{err}")
    Ok(None) => fail("cpal v1 table missing")
    Ok(Some(cpal)) => cpal
  }
  assert_eq(cpal.version, 1)
  assert_true(cpal.num_palettes > 0)
  assert_true(cpal.num_colors > 0)
  guard cpal.palette_flags is Some(flags) && flags.length() == cpal.num_palettes else {
    fail("expected palette flags for v1")
  }
  guard cpal.palette_labels is Some(labels) && labels.length() == cpal.num_palettes else {
    fail("expected palette labels for v1")
  }
  guard cpal.color_labels is Some(labels) && labels.length() == cpal.num_colors else {
    fail("expected color labels for v1")
  }
}

///|
test "colr v0 parse" {
  let font = Font::from_bytes(build_font_bytes_chromacheck_colr())
  let colr = match font.colr() {
    Err(err) => fail("colr v0 parse failed: \{err}")
    Ok(None) => fail("colr table missing")
    Ok(Some(colr)) => colr
  }
  assert_eq(colr.version, 0)
  assert_true(colr.base_glyphs.length() > 0)
  assert_true(colr.layers.length() > 0)
  let record = colr.base_glyphs[0]
  let layers = colr.glyph_layers(record.glyph_id)
  guard layers is Some(items) && items.length() == record.num_layers else {
    fail("expected glyph layers")
  }
}

///|
test "colr v1 parse" {
  let font = Font::from_bytes(build_font_bytes_noto_handwriting_colr1())
  let colr = match font.colr() {
    Err(err) => fail("colr v1 parse failed: \{err}")
    Ok(None) => fail("colr table missing")
    Ok(Some(colr)) => colr
  }
  assert_true(colr.version >= 1)
  assert_true(colr.base_glyph_paints.length() > 0)
  let record = colr.base_glyph_paints[0]
  let paint = colr.paint_at(record.paint_offset)
  match paint {
    Err(err) => fail("paint parse failed: \{err}")
    Ok(_) => ()
  }
}

///|
test "colr v1 walk paint" {
  let font = Font::from_bytes(build_font_bytes_noto_handwriting_colr1())
  let colr = match font.colr() {
    Err(err) => fail("colr v1 parse failed: \{err}")
    Ok(None) => fail("colr table missing")
    Ok(Some(colr)) => colr
  }
  let record = colr.base_glyph_paints[0]
  let paint = match colr.paint_at(record.paint_offset) {
    Err(err) => fail("paint parse failed: \{err}")
    Ok(value) => value
  }
  let count = match colr.walk_paint(paint, (_, _) => true) {
    Err(err) => fail("walk paint failed: \{err}")
    Ok(value) => value
  }
  assert_true(count > 0)
}

///|
test "colr clip extents none for v0" {
  let font = Font::from_bytes(build_font_bytes_chromacheck_colr())
  let colr = match font.colr() {
    Err(err) => fail("colr v0 parse failed: \{err}")
    Ok(None) => fail("colr table missing")
    Ok(Some(colr)) => colr
  }
  let record = colr.base_glyphs[0]
  let extents = colr.clip_extents_for_glyph(record.glyph_id)
  assert_true(extents is None)
}
