///|
fn post_standard_name(index : Int) -> String? {
  if index < 0 || index >= post_standard_names.length() {
    None
  } else {
    Some(post_standard_names[index])
  }
}

///|
fn post_standard_index(name : String) -> Int? {
  for i in 0..<post_standard_names.length() {
    if post_standard_names[i] == name {
      return Some(i)
    }
  }
  None
}

///|
pub fn PostTable::glyph_name(self : PostTable, glyph : Int) -> String? {
  if glyph < 0 {
    return None
  }
  if self.version == 0x00010000 {
    return post_standard_name(glyph)
  }
  if self.version != 0x00020000 {
    return None
  }
  let indices = match self.glyph_name_indices {
    None => return None
    Some(value) => value
  }
  if glyph >= indices.length() {
    return None
  }
  let index = indices[glyph]
  let standard = post_standard_name(index)
  match standard {
    Some(value) => Some(value)
    None => {
      let custom_index = index - post_standard_names.length()
      if custom_index < 0 {
        return None
      }
      match self.custom_names {
        None => None
        Some(names) => if custom_index >= names.length() {
          None
        } else {
          Some(@utf8.decode_lossy(names[custom_index][:]))
        }
      }
    }
  }
}

///|
pub fn PostTable::glyph_from_name(self : PostTable, name : String) -> Int? {
  if name == "" {
    return None
  }
  if self.version == 0x00010000 {
    return post_standard_index(name)
  }
  if self.version != 0x00020000 {
    return None
  }
  let indices = match self.glyph_name_indices {
    None => return None
    Some(value) => value
  }
  for glyph in 0..<indices.length() {
    match self.glyph_name(glyph) {
      None => ()
      Some(value) => if value == name {
        return Some(glyph)
      }
    }
  }
  None
}
